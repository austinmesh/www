---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';

const projects = await getCollection('projects');
const sorted = projects.sort((a, b) => {
  const aDate = a.data.publishedAt?.getTime() ?? 0;
  const bDate = b.data.publishedAt?.getTime() ?? 0;
  return bDate - aDate;
});

const frontmatter = {
  title: 'Projects | Austin Mesh',
  description:
    "Writeups from Austin Mesh community members about radios, nodes, antennas, packet analyzers, software, towers, and anything else they've built.",
};
---
<BaseLayout frontmatter={frontmatter}>
  <h1>Projects</h1>
  <p>
    Writeups from Austin Mesh community members &mdash; radios, nodes, antennas,
    packet analyzers, software, towers, anything you've built. Want to add yours?
    See <a href="https://github.com/austinmesh/austinmesh#contributing-a-project">how to contribute a project</a>.
  </p>

  {sorted.length === 0 ? (
    <p><em>No projects published yet &mdash; be the first to contribute one!</em></p>
  ) : (
    <ul class="project-grid">
      {sorted.map((project) => (
        <li>
          <a href={`/projects/${project.slug}/`}>
            <Image
              src={project.data.thumbnail}
              alt={project.data.thumbnailAlt}
              widths={[240, 480, 720]}
              sizes="(min-width: 960px) 280px, (min-width: 720px) 45vw, 100vw"
            />
            <h2>{project.data.title}</h2>
            <p>{project.data.description}</p>
            {project.data.author && <p class="project-author">by {project.data.author}</p>}
          </a>
        </li>
      ))}
    </ul>
  )}
</BaseLayout>
